<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.assetmanagement.backend.mapper.CategoryMapper">

    <select id="findAll" resultType="com.assetmanagement.backend.entity.Category">
        SELECT * FROM category ORDER BY id ASC
    </select>

    <select id="findById" resultType="com.assetmanagement.backend.entity.Category">
        SELECT * FROM category WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO category (name, use_ocr)
        VALUES (#{name}, #{useOcr})
    </insert>

    <update id="update">
        UPDATE category
        SET name = #{name},
            use_ocr = #{useOcr}
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM category WHERE id = #{id}
    </delete>

</mapper>
